NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY
NEXT_PUBLIC_AUTH_EMAIL_DOMAIN=workdesk.newhope.local

# Server-only secret used by:
# 1) scripts/bootstrap-users.mjs on the setup computer
# 2) the manager User Administration screen to create users and reset passwords
# Add this as a protected server environment variable in Vercel.
# Never prefix it with NEXT_PUBLIC and never expose it to browser code.
SUPABASE_SECRET_KEY=sb_secret_YOUR_SECRET_KEY
# Legacy alternative if your project uses legacy keys:
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Google Maps API key (client-side, for Places Autocomplete on the intake form address field)
# Enable "Maps JavaScript API" and "Places API" in your Google Cloud Console.
# Restrict to your Vercel domains under HTTP referrers.
# https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
